# =================================================================
# EresumeHub - Elite Generation 5 Environment Template
# =================================================================

# --- 🧠 AI PROVIDERS ---
# Get keys from OpenRouter, Groq, or Gemini
OPENROUTER_API_KEY="sk-..."
GROQ_API_KEY="gsk_..."
GEMINI_API_KEY="AIza..."

# --- 🕋 STORAGE (Supabase) ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="eyJ..."

# --- 🚀 INFRASTRUTURE (Redis / Worker) ---
# Default to local for dev, override with Render connection string for prod
REDIS_URL="redis://localhost:6379"

# --- 🛡️ SECURITY ---
# Comma-separated list of allowed origins (No wildcards in prod!)
ALLOWED_ORIGINS="https://eresumehub.netlify.app,http://localhost:3000"
# High-entropy secret for HMAC job protection and API access
API_SECRET_KEY="staff-level-secret-replace-in-production-immediately"

# --- ⚙️ CONFIGURATION ---
MAX_FILE_SIZE_MB=10
AI_REQUEST_TIMEOUT=120
CACHE_TTL=3600
ENABLE_LOGGING=True

# --- 🧪 TEST MODE ---
AI_TEST_MODE=False
AI_TEST_PROVIDER="openrouter:mistral-7b"
